# Copy this file to .env and adjust values as needed.
# .env is gitignored — never commit real secrets, even for a local academic project.

# --- General ---
APP_ENV=development
LOG_LEVEL=INFO

# --- MongoDB ---
MONGO_DB_NAME=smart_city_db
MONGO_PORT=27017
# Note: the backend connects to Mongo via the Docker network hostname "mongo"
# (see docker-compose.yml). MONGO_PORT here only controls the HOST-side
# port mapping, useful if you want to inspect the DB with a local GUI tool
# (e.g. MongoDB Compass) at mongodb://localhost:27017.

# --- Backend ---
BACKEND_PORT=8000
CORS_ALLOW_ORIGINS=*

# --- Frontend ---
FRONTEND_PORT=8080
