{
  "version": 1,
  "author": "Smart City Project Team",
  "editor": "wokwi",
  "parts": [
    { "type": "board-esp32-devkit-c-v4", "id": "esp32", "top": 0, "left": 0, "attrs": {} },
    { "type": "wokwi-potentiometer", "id": "pot1", "top": -40, "left": 300, "attrs": {} },
    { "type": "wokwi-pir-motion-sensor", "id": "pir1", "top": 60, "left": 300, "attrs": {} },
    { "type": "wokwi-hc-sr04", "id": "hcsr1", "top": 160, "left": 300, "attrs": {} },
    { "type": "wokwi-led", "id": "led1", "top": 260, "left": 300, "attrs": { "color": "yellow" } },
    { "type": "wokwi-resistor", "id": "r1", "top": 260, "left": 250, "attrs": { "value": "220" } }
  ],
  "connections": [
    ["esp32:TX", "$serialMonitor:RX", "", []],
    ["esp32:RX", "$serialMonitor:TX", "", []],

    ["pot1:SIG", "esp32:D34", "green", []],
    ["pot1:VCC", "esp32:3V3", "red", []],
    ["pot1:GND", "esp32:GND.1", "black", []],

    ["pir1:OUT", "esp32:D27", "green", []],
    ["pir1:VCC", "esp32:3V3", "red", []],
    ["pir1:GND", "esp32:GND.1", "black", []],

    ["hcsr1:TRIG", "esp32:D26", "green", []],
    ["hcsr1:ECHO", "esp32:D25", "yellow", []],
    ["hcsr1:VCC", "esp32:VIN", "red", []],
    ["hcsr1:GND", "esp32:GND.1", "black", []],

    ["esp32:D32", "r1:1", "orange", []],
    ["r1:2", "led1:A", "orange", []],
    ["led1:C", "esp32:GND.1", "black", []]
  ],
  "dependencies": {}
}
