# Copy this file to backend/.env for running the backend directly (venv,
# no Docker) — e.g. to run `pytest -m integration` locally. This is
# separate from the .env.example at the project root, which is
# docker-compose's own variable-interpolation file for the containerized
# stack (a different mechanism from pydantic-settings' env_file lookup
# used here).
#
# This dev machine has no local MongoDB — point MONGO_URI at the same
# Atlas cluster used for the Render deployment, but with a DIFFERENT
# MONGO_DB_NAME than production ("smart_city_db" on Render). Integration
# tests refuse to run against "smart_city_db" as a safety guard (see
# tests/integration/conftest.py) since they drop collections at teardown.

APP_ENV=development
LOG_LEVEL=INFO

MONGO_URI=mongodb+srv://<user>:<password>@<cluster-host>/?retryWrites=true&w=majority&appName=<app-name>
MONGO_DB_NAME=smart_city_test

CORS_ALLOW_ORIGINS=*

# --- Auth (Milestone 4) ---
# Required -- Settings() fails fast at startup if unset, including when
# running any regression test (they boot the full app via TestClient).
SECRET_KEY=change-me-to-a-long-random-string-for-local-dev
ACCESS_TOKEN_EXPIRE_MINUTES=60
# Password for the seed script's default "admin" user. Leave unset to skip
# admin-user seeding; regression tests that log in need this set.
ADMIN_SEED_PASSWORD=change-me
# Password for the seed script's "lamp-device" operator user -- the shared
# credential the Milestone 5 ESP32 firmware logs in as. Leave unset to skip.
DEVICE_SEED_PASSWORD=change-me-too
